AIOPS_ENVIRONMENT=dev
AIOPS_COMMAND_TIMEOUT_SECONDS=40
AIOPS_ENABLE_OPENAI_ENRICHMENT=true
AIOPS_OPENAI_API_KEY=
AIOPS_OPENAI_MODEL=gpt-4.1-mini
AIOPS_REQUIRE_API_KEY=true
AIOPS_API_KEYS_ADMIN=admin-dev-key
AIOPS_API_KEYS_OPERATOR=operator-dev-key
AIOPS_API_KEYS_VIEWER=viewer-dev-key
AIOPS_STATE_DB_PATH=./data/aiops_hub.db
AIOPS_CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
